            margin: 50px 0;
            padding: 30px;
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            border-radius: 20px;
        }

        .timeline h3 {
            text-align: center;
            font-size: 1.8rem;
            color: #333;
            margin-bottom: 30px;
            font-weight: 700;
        }

        .timeline-items {
            position: relative;
            padding: 20px 0;
        }

        .timeline-item {
            display: flex;
            align-items: center;
            margin-bottom: 30px;
            position: relative;
        }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: 30px;
            top: 50px;
            width: 2px;
            height: calc(100% + 10px);
            background: linear-gradient(180deg, #667eea, #764ba2);
        }

        .timeline-item:last-child::before {
            display: none;
        }

        .timeline-dot {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 30px;
            flex-shrink: 0;
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.3);
        }

        .timeline-dot i {
            font-size: 1.5rem;
            color: white;
        }

        .timeline-content h4 {
            font-size: 1.2rem;
            color: #333;
            margin-bottom: 5px;
            font-weight: 600;
        }

        .timeline-content p {
            color: #666;
            font-size: 1rem;
            margin: 0;
        }

        @media (max-width: 768px) {
            .welcome-container {
                margin: 10px;
            }
            
            .header h1 {
                font-size: 2rem;
            }
            
            .stats-container,
            .features,
            .services-grid {
                grid-template-columns: 1fr;
            }
            
            .user-info {
                flex-direction: column;
                text-align: center;
            }
            
            .user-avatar {
                margin-right: 0;
                margin-bottom: 20px;
            }
            
            .action-buttons {
                flex-direction: column;
                align-items: center;
            }
            
            .btn {
                width: 100%;
                max-width: 300px;
            }
        }
    </style>
</head>
<body>
    <!-- Animated Background -->
    <div class="bg-animation">
        <span></span>
        <span></span>
        <span></span>
        <span></span>
        <span></span>
        <span></span>
        <span></span>
        <span></span>
        <span></span>
        <span></span>
    </div>

    <div class="welcome-container">
        <div class="header">
            <div class="header-content">
                <h1>Welcome to Smart Workflow Tools!</h1>
                <p>Your journey to productivity starts here</p>
            </div>
        </div>

        <div class="content">
            <!-- Success Message -->
            <div class="success-message">
                <i class="fas fa-check-circle"></i>
                <div class="success-content">
                    <h3>Registration Successful!</h3>
                    <p>Your account is ready to use. Explore all our powerful features and tools.</p>
                </div>
            </div>

            <!-- Stats Section -->
            <div class="stats-container">
                <div class="stat-card">
                    <div class="stat-number">5+</div>
                    <div class="stat-label">Microservices</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">24/7</div>
                    <div class="stat-label">Availability</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">100%</div>
                    <div class="stat-label">Secure</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">AI</div>
                    <div class="stat-label">Powered</div>
                </div>
            </div>

            <!-- User Information -->
            <div class="user-info">
                <div class="user-avatar">
                    <i class="fas fa-user"></i>
                </div>
                <div class="user-details">
                    <h2><%= user.username %></h2>
                    <p><i class="fas fa-envelope"></i> <%= user.email %></p>
                    <p><i class="fas fa-clock"></i> Joined: <%= new Date().toLocaleDateString() %></p>
                    <span class="user-badge"><%= user.userType || 'Member' %></span>
                </div>
            </div>

            <!-- Features Section -->
            <div class="features">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-rocket"></i>
                    </div>
                    <div class="feature-title">Get Started</div>
                    <div class="feature-description">Complete your profile and explore all available services. Set up your preferences and start your journey.</div>
                    <div class="feature-progress">
                        <div class="feature-progress-bar" style="width: 75%;"></div>
                    </div>
                </div>

                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <div class="feature-title">Secure & Private</div>
                    <div class="feature-description">Your data is protected with enterprise-grade security and end-to-end encryption.</div>
                    <div class="feature-progress">
                        <div class="feature-progress-bar" style="width: 100%;"></div>
                    </div>
                </div>

                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-cogs"></i>
                    </div>
                    <div class="feature-title">Powerful Tools</div>
                    <div class="feature-description">Access all our microservices from one dashboard. Resume scanner, email marketing, and more.</div>
                    <div class="feature-progress">
                        <div class="feature-progress-bar" style="width: 90%;"></div>
                    </div>
                </div>
            </div>

            <!-- Services Grid -->
            <div class="services-grid">
                <div class="service-item">
                    <div class="service-icon">
                        <i class="fas fa-file-alt"></i>
                    </div>
                    <div class="service-info">
                        <h4>Resume Scanner</h4>
                        <p>AI-powered resume analysis</p>
                    </div>
                </div>

                <div class="service-item">
                    <div class="service-icon">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <div class="service-info">
                        <h4>Email Marketing</h4>
                        <p>Automated email campaigns</p>
                    </div>
                </div>

                <div class="service-item">
                    <div class="service-icon">
                        <i class="fas fa-google"></i>
                    </div>
                    <div class="service-info">
                        <h4>Gmail Automation</h4>
                        <p>Smart email management</p>
                    </div>
                </div>

                <div class="service-item">
                    <div class="service-icon">
                        <i class="fas fa-code"></i>
                    </div>
                    <div class="service-info">
                        <h4>Developer Tools</h4>
                        <p>Code optimization utilities</p>
                    </div>
                </div>
            </div>

            <!-- Timeline Section -->
            <div class="timeline">
                <h3>Your Journey Starts Here</h3>
                <div class="timeline-items">
                    <div class="timeline-item">
                        <div class="timeline-dot">
                            <i class="fas fa-user-plus"></i>
                        </div>
                        <div class="timeline-content">
                            <h4>Account Created</h4>
                            <p>Your account has been successfully created and is ready to use.</p>
                        </div>
                    </div>

                    <div class="timeline-item">
                        <div class="timeline-dot">
                            <i class="fas fa-user-cog"></i>
                        </div>
                        <div class="timeline-content">
                            <h4>Complete Profile</h4>
                            <p>Add more details to your profile to personalize your experience.</p>
                        </div>
                    </div>

                    <div class="timeline-item">
                        <div class="timeline-dot">
                            <i class="fas fa-rocket"></i>
                        </div>
                        <div class="timeline-content">
                            <h4>Explore Services</h4>
                            <p>Discover and use all our powerful microservices and tools.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <a href="/profile" class="btn btn-primary">
                    <i class="fas fa-user"></i>
                    Go to Profile
                </a>
                <a href="/logout" class="btn btn-secondary">
                    <i class="fas fa-sign-out-alt"></i>
                    Logout
                </a>
            </div>
        </div>
    </div>
</body>
</html>
